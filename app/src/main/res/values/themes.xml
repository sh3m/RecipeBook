<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.RecipeBook" parent="android:Theme.Material.NoActionBar">
        <item name="android:colorPrimary">@color/accent</item>
        <item name="android:colorPrimaryDark">@color/accent_pressed</item>
        <item name="android:colorAccent">@color/accent</item>
        <item name="android:statusBarColor">@color/dark_surface</item>
        <item name="android:navigationBarColor">@color/dark_bg</item>
        <item name="android:windowBackground">@color/dark_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorBg">@color/dark_bg</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorSurface2">@color/dark_surface2</item>
        <item name="colorText">@color/dark_text</item>
        <item name="colorHint">@color/dark_hint</item>
        <item name="colorBorder">@color/dark_border</item>
    </style>

    <style name="Theme.RecipeBook.Light" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:colorPrimary">@color/accent</item>
        <item name="android:colorPrimaryDark">@color/accent_pressed</item>
        <item name="android:colorAccent">@color/accent</item>
        <item name="android:statusBarColor">@color/light_surface</item>
        <item name="android:navigationBarColor">@color/light_bg</item>
        <item name="android:windowBackground">@color/light_bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorBg">@color/light_bg</item>
        <item name="colorSurface">@color/light_surface</item>
        <item name="colorSurface2">@color/light_surface2</item>
        <item name="colorText">@color/light_text</item>
        <item name="colorHint">@color/light_hint</item>
        <item name="colorBorder">@color/light_border</item>
    </style>
</resources>
