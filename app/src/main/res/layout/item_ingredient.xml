<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="44dp"
    android:layout_marginBottom="8dp"
    android:background="?attr/colorSurface2"
    android:orientation="horizontal">

    <EditText
        android:id="@+id/etIngredient"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:hint="Ingredient"
        android:inputType="textCapSentences"
        android:paddingStart="12dp" android:paddingEnd="12dp"
        android:textColor="?attr/colorText"
        android:textColorHint="?attr/colorHint"
        android:textSize="14sp" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="?attr/colorBorder" />

    <EditText
        android:id="@+id/etAmount"
        android:layout_width="90dp"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:gravity="end|center_vertical"
        android:hint="Amount"
        android:paddingStart="10dp" android:paddingEnd="10dp"
        android:textColor="?attr/colorText"
        android:textColorHint="?attr/colorHint"
        android:textSize="14sp" />

    <ImageButton
        android:id="@+id/btnRemove"
        android:layout_width="36dp"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:contentDescription="Remove"
        android:src="@drawable/ic_delete"
        android:tint="?attr/colorHint"
        android:alpha="0.6" />
</LinearLayout>
